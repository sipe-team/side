{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm build:tokens && docusaurus start",
    "build": "pnpm build:tokens && docusaurus build",
    "build:tokens": "pnpm --filter @sipe-team/tokens build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "pretypecheck": "pnpm build:tokens",
    "typecheck": "tsc",
    "clean": "rm -rf node_modules build .docusaurus"
  },
  "dependencies": {
    "@docusaurus/core": "3.6.3",
    "@docusaurus/preset-classic": "3.6.3",
    "@mdx-js/react": "^3.0.0",
    "@sipe-team/accordion": "workspace:*",
    "@sipe-team/avatar": "workspace:*",
    "@sipe-team/button": "workspace:*",
    "@sipe-team/checkbox": "workspace:*",
    "@sipe-team/icon": "workspace:*",
    "@sipe-team/tokens": "workspace:*",
    "@sipe-team/typography": "workspace:*",
    "clsx": "^2.0.0",
    "pretendard": "^1.3.9",
    "prism-react-renderer": "^2.3.0",
    "react": "catalog:react",
    "react-dom": "catalog:react"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.6.3",
    "@docusaurus/tsconfig": "3.6.3",
    "@docusaurus/types": "3.6.3",
    "@vanilla-extract/webpack-plugin": "^2.3.0",
    "typescript": "~5.6.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  }
}
